              </div>

              <div style={styles.card}>
                <div style={styles.sectionTitle}>Financial Snapshot</div>
                <div style={{ ...styles.card, marginBottom: 10 }}>
                  <div style={styles.cardTitle}>Total Fees Received</div>
                  <div style={styles.cardValue}>{currency(totals.totalFees)}</div>
