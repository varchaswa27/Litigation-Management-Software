                <label style={styles.label}>Nature of Case</label>
                <select style={styles.input} value={form.caseType} onChange={(e) => updateForm("caseType", e.target.value)}>
                  {caseTypes.map((type) => (
                    <option key={type} value={type}>{type}</option>
