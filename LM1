        )}
      </div>

      {modal.open && modal.selected && (
        <div style={styles.modalOverlay} onClick={() => setModal({ open: false, title: "", body: "", selected: null })}>
          <div style={styles.modal} onClick={(e) => e.stopPropagation()}>
            <div style={styles.modalTitle}>{modal.title}</div>
            <textarea readOnly style={{ ...styles.textarea, minHeight: 280 }} value={modal.body} />
            <div style={{ display: "flex", gap: 10, flexWrap: "wrap", marginTop: 14 }}>
              <button
                type="button"
                style={styles.secondaryButton}
                onClick={() => openEmailDraft(`${modal.title} - ${modal.selected.internalCaseNumber}`, modal.body, modal.selected.clientEmail)}
              >
                Send by Email
              </button>
              <button
                type="button"
                style={styles.secondaryButton}
                onClick={() => openWhatsappDraft(modal.body, modal.selected.clientWhatsapp)}
              >
                Send by WhatsApp
              </button>
              <button
                type="button"
                style={styles.primaryButton}
                onClick={() => setModal({ open: false, title: "", body: "", selected: null })}
              >
                Close
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
