              </div>

              <div style={styles.fullWidth}>
                <label style={styles.label}>Notes / Reporting Summary</label>
                <textarea style={styles.textarea} value={form.notes} onChange={(e) => updateForm("notes", e.target.value)} placeholder="Add facts, notice details, hearing notes, status update, advisory remarks or next action items" />
