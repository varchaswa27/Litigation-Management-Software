              <div style={styles.fullWidth}>
                <label style={styles.label}>Upload Case Documents</label>
                <input type="file" multiple style={styles.input} onChange={handleFileUpload} />
                <div style={{ marginTop: 12 }}>
                  {form.documents.map((doc, idx) => (
                    <div key={`${doc.name}-${idx}`} style={{ ...styles.card, padding: 10, marginBottom: 8 }}>
                      <strong>{doc.name}</strong>
                      <div style={styles.smallText}>{doc.category} • {doc.size}</div>
                    </div>
