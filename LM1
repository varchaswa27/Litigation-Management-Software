function currency(n) {
  return new Intl.NumberFormat("en-IN", {
    style: "currency",
    currency: "INR",
    maximumFractionDigits: 0,
  }).format(Number(n || 0));
}

function generateCaseNumber(existing) {
  const year = new Date().getFullYear();
  const next = String(existing.length + 1).padStart(4, "0");
  return `LIT-${year}-${next}`;
}

function formatDate(value) {
  if (!value) return "—";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toLocaleDateString("en-IN", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
}

function generateInvoice(caseItem) {
  const balance = Number(caseItem.clientFeesPaid || 0) - Number(caseItem.amountSpent || 0);
  return `Invoice / Fee Statement\n\nBrand: Sandeep's Linklegal (OPC) Pvt. Ltd.\nInternal File No.: ${caseItem.internalCaseNumber}\nCourt Case No.: ${caseItem.actualCourtCaseNumber || "Not allotted / not entered"}\nMatter: ${caseItem.partyName}\nCourt: ${caseItem.court}\nCity: ${caseItem.litigationCity || "—"}\nStage: ${caseItem.stage}\nFees Paid by Client: ${currency(caseItem.clientFeesPaid)}\nAmount Spent on Matter: ${currency(caseItem.amountSpent)}\nCurrent Net Position: ${currency(balance)}\nNext Hearing Date: ${formatDate(caseItem.nextHearingDate)}\n\nThis is a system-generated invoice statement from Sandeep's Linklegal (OPC) Pvt. Ltd.`;
}

function generateCaseUpdate(caseItem) {
  return `Case Update\n\nBrand: Sandeep's Linklegal (OPC) Pvt. Ltd.\nInternal File No.: ${caseItem.internalCaseNumber}\nCourt Case No.: ${caseItem.actualCourtCaseNumber || "Not allotted / not entered"}\nMatter: ${caseItem.partyName}\nCourt: ${caseItem.court}\nCity: ${caseItem.litigationCity || "—"}\nCurrent Stage: ${caseItem.stage}\nNext Hearing Date: ${formatDate(caseItem.nextHearingDate)}\nNotes: ${caseItem.notes || "No remarks added."}\n\nThis update is system-generated for client communication.`;
}

