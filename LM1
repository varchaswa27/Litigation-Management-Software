export default function LitigationManagementWebsite() {
  const [cases, setCases] = useState(starterCases);
  const [search, setSearch] = useState("");
  const [tab, setTab] = useState("new-case");
  const [modal, setModal] = useState({ open: false, title: "", body: "", selected: null });
  const [form, setForm] = useState({
    caseType: "Civil",
    partyName: "",
    court: "District Court",
    litigationCity: "",
    stage: "Pre-Litigation",
    actualCourtCaseNumber: "",
    nextHearingDate: "",
    clientFeesPaid: "",
    amountSpent: "",
    clientEmail: "",
    clientWhatsapp: "",
    notes: "",
    documents: [],
  });

  const filteredCases = useMemo(() => {
    const q = search.toLowerCase();
    return cases.filter(
      (c) =>
        c.internalCaseNumber.toLowerCase().includes(q) ||
        (c.actualCourtCaseNumber || "").toLowerCase().includes(q) ||
        c.partyName.toLowerCase().includes(q) ||
        c.caseType.toLowerCase().includes(q) ||
        c.court.toLowerCase().includes(q) ||
        c.stage.toLowerCase().includes(q) ||
        (c.litigationCity || "").toLowerCase().includes(q)
    );
  }, [cases, search]);

  const totals = useMemo(() => {
    const totalFees = cases.reduce((sum, c) => sum + Number(c.clientFeesPaid || 0), 0);
    const totalSpent = cases.reduce((sum, c) => sum + Number(c.amountSpent || 0), 0);
    const openCases = cases.filter((c) => c.stage !== "Disposed").length;
    return { totalFees, totalSpent, openCases, totalCases: cases.length };
  }, [cases]);

  const typeBreakdown = useMemo(() => {
    return caseTypes
      .map((type) => ({
        type,
        count: cases.filter((c) => c.caseType === type).length,
      }))
      .filter((x) => x.count > 0);
  }, [cases]);

  const stageBreakdown = useMemo(() => {
    return stages
      .map((stage) => ({ stage, count: cases.filter((c) => c.stage === stage).length }))
      .filter((item) => item.count > 0);
  }, [cases]);

  function updateForm(field, value) {
    setForm((prev) => ({ ...prev, [field]: value }));
  }

  function handleFileUpload(e) {
    const files = Array.from(e.target.files || []);
    const mapped = files.map((file) => ({
      name: file.name,
      size: `${(file.size / 1024 / 1024).toFixed(2)} MB`,
      category: "Uploaded Document",
    }));
    setForm((prev) => ({ ...prev, documents: [...prev.documents, ...mapped] }));
  }

  function handleCreateCase() {
    if (!form.partyName.trim()) {
      alert("Please enter Party Name.");
      return;
    }

    const newCase = {
      id: Date.now(),
      internalCaseNumber: generateCaseNumber(cases),
      actualCourtCaseNumber: form.actualCourtCaseNumber,
      caseType: form.caseType,
      partyName: form.partyName,
      court: form.court,
      litigationCity: form.litigationCity,
      stage: form.stage,
      nextHearingDate: form.nextHearingDate,
      clientFeesPaid: Number(form.clientFeesPaid || 0),
      amountSpent: Number(form.amountSpent || 0),
      clientEmail: form.clientEmail,
      clientWhatsapp: form.clientWhatsapp,
      notes: form.notes,
      documents: form.documents,
      createdAt: new Date().toISOString().slice(0, 10),
    };

    setCases((prev) => [newCase, ...prev]);
    setForm({
      caseType: "Civil",
      partyName: "",
      court: "District Court",
      litigationCity: "",
      stage: "Pre-Litigation",
      actualCourtCaseNumber: "",
      nextHearingDate: "",
      clientFeesPaid: "",
      amountSpent: "",
      clientEmail: "",
      clientWhatsapp: "",
      notes: "",
      documents: [],
    });
    setTab("case-register");
  }

  function openInvoice(caseItem) {
    setModal({
      open: true,
      title: "Invoice Preview",
      body: generateInvoice(caseItem),
      selected: caseItem,
    });
  }

  function openUpdate(caseItem) {
    setModal({
      open: true,
      title: "Case Update Preview",
      body: generateCaseUpdate(caseItem),
      selected: caseItem,
    });
  }

  function openEmailDraft(subject, body, email) {
    if (!email) {
      alert("Client email is missing for this matter.");
      return;
    }
    window.open(`mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`);
  }

  function openWhatsappDraft(body, whatsapp) {
    const cleanNumber = (whatsapp || "").replace(/[^\d]/g, "");
    if (!cleanNumber) {
      alert("Client WhatsApp number is missing for this matter.");
      return;
    }
    window.open(`https://wa.me/${cleanNumber}?text=${encodeURIComponent(body)}`, "_blank");
  }

