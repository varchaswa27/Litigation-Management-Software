                    <th style={styles.th}>Court</th>
                    <th style={styles.th}>City</th>
                    <th style={styles.th}>Stage</th>
                    <th style={styles.th}>Next Hearing</th>
                    <th style={styles.th}>Fees Paid</th>
                    <th style={styles.th}>Spent</th>
                    <th style={styles.th}>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {filteredCases.map((item) => (
                    <tr key={item.id}>
                      <td style={styles.td}><strong>{item.internalCaseNumber}</strong></td>
                      <td style={styles.td}>{item.actualCourtCaseNumber || "—"}</td>
                      <td style={styles.td}><span style={styles.badge}>{item.caseType}</span></td>
                      <td style={styles.td}>{item.partyName}</td>
                      <td style={styles.td}>{item.court}</td>
                      <td style={styles.td}>{item.litigationCity || "—"}</td>
                      <td style={styles.td}>{item.stage}</td>
                      <td style={styles.td}>{formatDate(item.nextHearingDate)}</td>
                      <td style={styles.td}>{currency(item.clientFeesPaid)}</td>
                      <td style={styles.td}>{currency(item.amountSpent)}</td>
                      <td style={styles.td}>
                        <div style={styles.actionRow}>
                          <button type="button" style={styles.secondaryButton} onClick={() => openInvoice(item)}>Invoice</button>
                          <button type="button" style={styles.secondaryButton} onClick={() => openUpdate(item)}>Update</button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {tab === "reporting" && (
          <div style={{ display: "grid", gap: 16 }}>
            <div style={styles.reportGrid}>
              <div style={styles.card}>
                <div style={styles.sectionTitle}>Case Type Breakdown</div>
                {typeBreakdown.map((item) => {
