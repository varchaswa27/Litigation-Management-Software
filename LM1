              </div>

              <div>
                <label style={styles.label}>Next Date of Hearing</label>
                <input type="date" style={styles.input} value={form.nextHearingDate} onChange={(e) => updateForm("nextHearingDate", e.target.value)} />
              </div>

              <div>
                <label style={styles.label}>Fees Paid by Client</label>
